# ==============================================================================
# FakeStore ETL Pipeline - Environment Variables Template
# ==============================================================================
# Instructions:
# 1. Copy this file and rename the copy to '.env'
# 2. Fill in your real secrets and credentials in the '.env' file
# 3. DO NOT commit the actual '.env' file to Git! (.env is already in .gitignore)
# ==============================================================================

# 1. Database Infrastructure Configuration (Used by Docker Compose)
DB_USER=your_database_username_here
DB_PASSWORD=your_secure_password_here
DB_NAME=your_database_name_here
DB_PORT=5432

# 2. Python Connection String (Used by SQLAlchemy / Pandas)
# You can use the explicit format below directly in your .env file:
DATABASE_URL=postgresql://your_database_username_here:your_secure_password_here@localhost:5432/your_database_name_here

# 3. Pipeline Configurations (Optional)
APP_ENV=development